<?xml version="1.0" encoding="utf-8"?>
<!-- Allow plain-HTTP to the Gemini / Google TTS / Sarvam REST endpoints
     (all use HTTPS; this config is a safety net for debug builds) -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
